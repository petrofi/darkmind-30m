{
  "run_name": "darkmind_30m",
  "data_path": "data/corpus_v1.txt",
  "tokenizer_dir": "tokenizer/darkmind-tokenizer",
  "checkpoint_path": "checkpoints/darkmind_30m.pt",
  "seed": 42,
  "model": {
    "block_size": 256,
    "n_layer": 8,
    "n_head": 8,
    "n_embd": 512,
    "dropout": 0.1
  },
  "training": {
    "batch_size": 8,
    "max_steps": 300,
    "eval_interval": 50,
    "eval_iters": 5,
    "learning_rate": 0.0003,
    "train_ratio": 0.9,
    "min_tokens": 200000
  }
}