{
  "run_name": "darkmind_50m_experimental",
  "data_path": "data/processed/corpus_v3.txt",
  "tokenizer_dir": "tokenizer/darkmind-tokenizer",
  "checkpoint_path": "checkpoints/darkmind_50m_experimental.pt",
  "seed": 42,
  "notes": "Experimental larger config. This may be too heavy for the current GPU/RAM budget; test carefully with short runs before long training.",
  "model": {
    "block_size": 256,
    "n_layer": 10,
    "n_head": 8,
    "n_embd": 640,
    "dropout": 0.1
  },
  "training": {
    "batch_size": 4,
    "max_steps": 1000,
    "eval_interval": 100,
    "eval_iters": 5,
    "learning_rate": 0.00025,
    "train_ratio": 0.9,
    "min_tokens": 250000
  }
