{
  "schema_version": "darkmind-v2-corpus-v3-targets-v1",
  "default_target_tokens": 500000000,
  "planning_levels": {
    "minimum_experimental_tokens": 100000000,
    "first_serious_base_training_tokens": 250000000,
    "preferred_public_candidate_tokens": 500000000
  },
  "training_stages_tokens": [5000000, 25000000, 100000000, 250000000, 500000000],
  "exclusive_composition": {
    "turkish_high_quality_prose": {
      "target_percent": 60,
      "allowed_percent": [55, 65]
    },
    "english_high_quality_prose": {
      "target_percent": 25,
      "allowed_percent": [20, 30]
    },
    "technical_and_educational": {
      "target_percent": 8,
      "allowed_percent": [8, 12]
    },
    "code_and_structured_text": {
      "target_percent": 4,
      "allowed_percent": [3, 7]
    },
    "controlled_bilingual_or_dialogue": {
      "target_percent": 3,
      "allowed_percent": [0, 5]
    }
  },
  "document_assignment_policy": "Each accepted document belongs to exactly one exclusive quota category.",
  "languages": ["tr", "en"],
  "tokenizer": "darkmind_v2_sp_bpe24k_v1",
  "token_storage_dtype": "uint16",
  "maximum_single_source_percent": 35,
  "quality_tiers": ["A", "B", "C", "rejected"],
  "split_policy": {
    "train_percent": 90,
    "validation_percent": 5,
    "eval_percent": 5,
    "document_family_isolation": true,
    "evaluation_prompt_contamination_block": true
  }
}
